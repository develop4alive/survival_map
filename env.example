# Survival Map — секреты и per-deployment настройки.
# Остальное (БД, матчер, прокси, TTL и т.п.) — в core/settings.py.

# Токен бота от @BotFather. Обязателен — без него core не стартует.
BOT_TOKEN=your_bot_token_here

# Доступ только из Telegram (Mini App). False (дефолт) = открытый доступ.
# Для production Mini App выставить True.
TELEGRAM_VALIDATION_ENABLED=False

# Публичный HTTPS-URL приложения (кнопка бота + настройка в @BotFather).
# Для локального запуска можно не задавать.
WEBAPP_URL=

# Куда редиректить не-Telegram трафик при TELEGRAM_VALIDATION_ENABLED=True.
REDIRECT_URL=https://github.com/404

# JWT-секрет автогенерируется при старте. Задать (≥32 символов) только если нужен
# стабильный/общий секрет между рестартами или репликами core.
# JWT_SECRET=
