# =============================================================================
#               CREDENTIALS
#
# Всё остальное (DB-параметры, калибровка матчера, прокси, логирование, CORS,
# Redis host/port, JWT TTL, лимиты парсера) централизовано в `core/settings.py`
# как hardcoded defaults в соответствующих @dataclass. Чтобы поменять — правь
# core/settings.py, не env
# =============================================================================

# === SECRETS (обязательно изменить в production!) ===

# Telegram bot token от @BotFather
BOT_TOKEN=your_bot_token_here

# JWT_SECRET в env НЕ нужен — секрет автогенерируется в памяти при старте core
# (см. core/settings.py _resolve_jwt_secret). Задайте JWT_SECRET (≥32 символов)
# здесь ТОЛЬКО если нужен стабильный секрет между рестартами или общий на
# несколько реплик core.
JWT_SECRET=your_jwt_here

# === DEPLOYMENT URLS / WEBAPP (для Telegram Mini App) ===

# Публичный HTTPS-URL приложения. Нужен для production Mini App: бот вставляет
# его в кнопку «Открыть приложение», этот же URL задаётся в @BotFather.
# Для локальной проверки в браузере можно оставить пустым.
WEBAPP_URL=

# Режим доступа к приложению:
#   True  — доступ только из Telegram (production Mini App). Значение по умолчанию.
#   False — открытый доступ без авторизации, ТОЛЬКО для локальной проверки в браузере.
# Принимаемые значения: True/False, 1/0, yes/no, on/off. ПУСТЫМ НЕ ОСТАВЛЯТЬ —
# пустое значение валит старт core (env.bool не парсит "").
TELEGRAM_VALIDATION_ENABLED=True

# Куда отправлять не-Telegram трафик при включённой валидации.
REDIRECT_URL=https://github.com/404

# === OPTIONAL OVERRIDES ===

# Порог схожести для лексического матчера
ENTITY_SIMILARITY_THRESHOLD=0.75

