# =============================================================================
# .env.example — ТОЛЬКО credentials и per-deployment URL.
#
# Всё остальное (DB-параметры, калибровка матчера, прокси, логирование, CORS,
# Redis host/port, JWT TTL, лимиты парсера) централизовано в `core/settings.py`
# как hardcoded defaults в соответствующих @dataclass. Чтобы поменять — правь
# code, не env.
# =============================================================================

# === SECRETS (обязательно изменить в production!) ===

# Telegram bot token от @BotFather
BOT_TOKEN=your_bot_token_here

# JWT секрет ≥32 символа.
# Генерация: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=REPLACE_WITH_SECURE_KEY_MIN_32_CHARS

# === DEPLOYMENT IDENTITY ===

# ID Telegram-канала для мониторинга. Должен начинаться с -100.
CHANNEL_ID=

# === DEPLOYMENT URLS (опционально, для Telegram WebApp) ===

# Публичный HTTPS-URL приложения (для BotFather webapp configuration).
WEBAPP_URL=

# Валидаия telegram webview
TELEGRAM_VALIDATION_ENABLED=

# Куда отправлять не-Telegram трафик при включённой валидации.
REDIRECT_URL=

# === OPTIONAL OVERRIDES ===

# Валидация Telegram InitData при заходе в Mini App (защита от non-Telegram
# трафика). По умолчанию True. Установить False ТОЛЬКО для dev-режима — иначе
# любой может зайти в app без проверки.
# Принимаемые значения: True/False, 1/0, yes/no, on/off.
#TELEGRAM_VALIDATION_ENABLED=True
